# Release signing for Android. Copy to `keystore.properties` (git-ignored) for
# local release builds, or set the equivalent CI secrets (see
# .github/workflows/release.yml, the build-android job).
#
# CRITICAL: use ONE keystore for every Quark release, forever. Android will not
# install an update whose signing certificate differs from the installed app —
# changing the key forces every user to uninstall (losing data) and reinstall.
# Back this keystore up somewhere safe; if you lose it you can never ship an
# upgradeable build to existing installs again.
#
# Generate a keystore once with:
#   keytool -genkeypair -v -keystore quark-release.jks \
#     -keyalg RSA -keysize 4096 -validity 10000 -alias quark
#
# Local                         CI env var
storeFile=/absolute/path/to/quark-release.jks   # ANDROID_KEYSTORE_PATH
storePassword=changeme                          # ANDROID_KEYSTORE_PASSWORD
keyAlias=quark                                  # ANDROID_KEY_ALIAS
keyPassword=changeme                            # ANDROID_KEY_PASSWORD
