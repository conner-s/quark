{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-schema/main/tauri.conf.json",
  "productName": "Quark",
  "version": "0.15.2",
  "identifier": "tel.quark.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1450",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IERGQjE2RDEyNkM0M0FDNgpSV1RHT3NRbTBSYjdEV3dEczdEQlJrbkdCWjkra052L3NISU1yZmQ0QVloRkVWcjY2NUpZWjB1Ywo=",
      "endpoints": [
        "https://quark.tel/updates/stable/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Quark",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' blob: data: https:; media-src 'self' blob: asset: http://asset.localhost http://127.0.0.1:*; connect-src 'self' ipc: http://ipc.localhost; font-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "publisher": "mcplummet",
    "homepage": "https://quark.tel",
    "license": "AGPL-3.0-or-later",
    "copyright": "Copyright (C) 2026 mcplummet",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "iOS": {
      "minimumSystemVersion": "17.0"
    }
  }
}
